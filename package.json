{
    "name": "distributed-rate-limiter",
    "version": "0.1.0",
    "description": "Phase 1: Redis-backed HTTP rate limiter with NestJS + Fastify",
    "main": "dist/main.js",
    "license": "MIT",
    "scripts": {
        "start": "ts-node src/main.ts",
        "start:dev": "nodemon --watch src --ext ts --exec \"ts-node src/main.ts\"",
        "build": "tsc -p tsconfig.build.json",
        "test": "vitest run",
        "test:watch": "vitest watch"
    },
    "dependencies": {
        "@nestjs/common": "^10.0.0",
        "@nestjs/core": "^10.0.0",
        "@nestjs/platform-fastify": "^10.0.0",
        "dotenv": "^16.4.5",
        "fastify": "^4.26.2",
        "ioredis": "^5.4.1",
        "reflect-metadata": "^0.1.13",
        "rxjs": "^7.8.1",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "@types/node": "^20.12.7",
        "@types/uuid": "^9.0.7",
        "@vitest/coverage-v8": "^1.4.0",
        "nodemon": "^3.1.0",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.4.3",
        "vitest": "^1.4.0"
    }
}
