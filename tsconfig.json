{
    "compilerOptions": {
        "module": "CommonJS",
        "target": "ES2019",
        "moduleResolution": "node",
        "outDir": "dist",
        "baseUrl": "./",
        "paths": {},
        "strict": true,
        "noImplicitAny": false,
        "sourceMap": true,
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "src/**/*",
        "test/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
